#include<string>
#include<cctype>
#include <algorithm>

class Solution
{

public:
    /*
     * 功能: 按 k 个有效字符一组重新格式化许可证密钥。
     * 参数: s 为包含字母、数字和破折号的原始密钥；k 为每组字符数量，取值大于 0。
     * 返回: 去除原破折号并转换为大写后的格式化字符串。
     */
    std::string licenseKeyFormatting(std::string s, int k)
    {
        std::size_t groupCount(0U);
        std::string contain{};
        std::string output{};
        const std::size_t groupSize = static_cast<std::size_t>(k);

        // 清理原分隔符并将有效字符转换为大写，作为后续分组的字符栈。
        for (const char char_: s)
        {
            if (char_ != '-')
            {
                contain.push_back(static_cast<char>(toupper(static_cast<int>(char_))));
            }
        }
        
        // 从尾部按 k 个字符分组，首组不足 k 个字符的情况会在反转后自然形成。
        while (!contain.empty())
        {
            output.push_back(contain.back());
            contain.pop_back();
            groupCount++;

            if(groupCount == groupSize && !contain.empty())
            {
                groupCount = 0U;
                output.push_back('-');
            }
        }
        // 尾部弹出会使字符顺序反转，最后恢复从左到右的显示顺序。
        std::reverse(output.begin(),output.end());
        return output;
    }
};
